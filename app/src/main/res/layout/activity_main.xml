<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0F1117" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="20dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="FlowDriver" android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔴 قطع" android:textColor="#FFFFFF" android:textSize="14sp"/>
        </LinearLayout>

        <!-- Auth Card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" app:cardBackgroundColor="#1E2130"
            app:cardCornerRadius="12dp" app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="فایل‌های احراز هویت" android:textColor="#8892A4"
                    android:textSize="12sp" android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="credentials.json" android:textColor="#FFFFFF" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvCredStatus" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="✗ وارد نشده"
                            android:textColor="#FF5252" android:textSize="11sp"/>
                    </LinearLayout>
                    <Button android:id="@+id/btnImportCredentials" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="انتخاب" android:textSize="12sp"
                        android:textColor="#7C83FD" android:backgroundTint="#2D3250"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="credentials.json.token" android:textColor="#FFFFFF" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvTokenStatus" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="✗ وارد نشده"
                            android:textColor="#FF5252" android:textSize="11sp"/>
                    </LinearLayout>
                    <Button android:id="@+id/btnImportToken" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="انتخاب" android:textSize="12sp"
                        android:textColor="#7C83FD" android:backgroundTint="#2D3250"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Settings Card -->
        <androidx.cardview.widget.CardView android:id="@+id/cardSettings" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#1E2130" app:cardCornerRadius="12dp" app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="تنظیمات" android:textColor="#8892A4" android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Google Folder ID" android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etFolderId" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#FFFFFF" android:backgroundTint="#3A3F55" android:inputType="text"
                    android:padding="10dp" android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Refresh (ms)" android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etRefreshRate" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textColor="#FFFFFF"
                            android:backgroundTint="#3A3F55" android:inputType="number" android:text="200" android:padding="10dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Flush (ms)" android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etFlushRate" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textColor="#FFFFFF"
                            android:backgroundTint="#3A3F55" android:inputType="number" android:text="300" android:padding="10dp"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Target IP:Port" android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etTargetIP" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#FFFFFF" android:backgroundTint="#3A3F55" android:hint="216.239.38.120:443"
                    android:inputType="text" android:padding="10dp" android:layout_marginBottom="8dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SNI" android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etSNI" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#FFFFFF" android:backgroundTint="#3A3F55" android:hint="google.com"
                    android:inputType="text" android:padding="10dp" android:layout_marginBottom="8dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Host Header" android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etHostHeader" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#FFFFFF" android:backgroundTint="#3A3F55" android:hint="www.googleapis.com"
                    android:inputType="text" android:padding="10dp" android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Insecure Skip Verify" android:textColor="#AAAAAA" android:textSize="13sp"/>
                    <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchInsecure"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="false"/>
                </LinearLayout>

                <Button android:id="@+id/btnSaveSettings" android:layout_width="match_parent" android:layout_height="44dp"
                    android:text="ذخیره تنظیمات" android:textColor="#7C83FD" android:backgroundTint="#2D3250"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Connect Button -->
        <Button android:id="@+id/btnToggle" android:layout_width="match_parent" android:layout_height="56dp"
            android:layout_marginBottom="12dp" android:text="اتصال" android:textColor="#FFFFFF"
            android:textSize="16sp" android:textStyle="bold" android:backgroundTint="#4CAF50"/>

        <!-- Log Card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E2130" app:cardCornerRadius="12dp" app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="لاگ" android:textColor="#8892A4" android:textSize="12sp"/>
                    <!-- دکمه کپی لاگ -->
                    <Button android:id="@+id/btnCopyLog" android:layout_width="wrap_content" android:layout_height="28dp"
                        android:text="📋 کپی" android:textSize="11sp" android:textColor="#7C83FD"
                        android:backgroundTint="#2D3250"
                        style="@style/Widget.MaterialComponents.Button.TextButton"/>
                    <Button android:id="@+id/btnClearLog" android:layout_width="wrap_content" android:layout_height="28dp"
                        android:text="پاک" android:textSize="11sp" android:textColor="#8892A4"
                        android:backgroundTint="#2D3250"
                        style="@style/Widget.MaterialComponents.Button.TextButton"/>
                </LinearLayout>

                <ScrollView android:id="@+id/scrollLog" android:layout_width="match_parent" android:layout_height="250dp">
                    <TextView android:id="@+id/tvLog" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:textColor="#7C83FD"
                        android:textSize="10sp" android:fontFamily="monospace" android:lineSpacingExtra="2dp"/>
                </ScrollView>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
